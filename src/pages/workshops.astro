---
import Base from '../layouts/Base.astro';
import { isPublished } from '../lib/content';
import workshopsData from '../../data/workshops.json';

const workshops = ((workshopsData as any).items || workshopsData).filter(isPublished);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Workshops — Jonas Haeg" description="Workshops and organised events by Jonas Haeg." page="workshops">
  <span class="eyebrow">Workshops</span>

  <ul class="pub-list">
    {workshops.map((w: any) => {
      const date = [w.month, w.year].filter(Boolean).join(' ');
      const metaParts = [
        w.institution,
        date,
        w.coorganisers ? `Organised with ${w.coorganisers}` : '',
      ].filter(Boolean);
      return (
        <li class="pub">
          <div class="yr">{w.year || ''}</div>
          <div>
            <h3><a href={`${base}/${w.id}`}>{w.title}</a></h3>
            <p class="venue">{metaParts.join(' · ')}.</p>
          </div>
        </li>
      );
    })}
  </ul>
</Base>
