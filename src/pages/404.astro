---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Page not found — Jonas Haeg" description="Page not found." page="404">
  <span class="eyebrow">404</span>
  <h2>Page not found</h2>
  <p style="color:var(--fg-2)">
    That page doesn't exist. Try <a href={`${base}/`}>the home page</a>,
    <a href={`${base}/research`}>Research</a>, or <a href={`${base}/cv`}>CV</a>.
  </p>
</Base>
