---
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import navData from '../../data/nav.json';
import projectsData from '../../data/projects.json';
import themeData from '../../data/theme.json';
import settings from '../../data/site-settings.json';
import { getThemeCss, getThemeFontLinks } from '../lib/theme';

const themeCss = getThemeCss(themeData as Record<string, string>);
const fontLinks = getThemeFontLinks(themeData as Record<string, string>);

interface Props {
  title: string;
  description?: string;
  page?: string;
  wideLayout?: boolean;
}

const { title, description, page, wideLayout = false } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Published research projects each get a page at /research/<id>. When any
// exist, the flat "Research" nav link becomes a dropdown (Publications +
// each project) so new projects show up automatically without editing nav.json.
const projects = (((projectsData as any).items) || []).filter((p: any) => p && p.published !== false);
const navItems = (navData.items as any[]).map(item => {
  if ((item.label || '').toLowerCase() === 'research' && projects.length > 0) {
    return {
      ...item,
      href: undefined,
      subitems: [
        { label: 'Publications', href: 'research' },
        ...projects.map((p: any) => ({ label: p.title, href: `research/${p.id}` })),
      ],
    };
  }
  return item;
});

const metaDesc = description || settings.description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(settings.og_image || '/assets/portrait.jpg', Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={metaDesc} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={ogImageURL} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={metaDesc} />
  <link rel="icon" type="image/svg+xml" href={`${base}/assets/favicon.svg`} />
  <link rel="stylesheet" href={`${base}/styles/style.css`} />
  {fontLinks.length > 0 && <link rel="preconnect" href="https://fonts.googleapis.com" />}
  {fontLinks.length > 0 && <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />}
  {settings.analytics_id && <link rel="preconnect" href="https://gateway.umami.is" />}
  {fontLinks.map(url => <link rel="stylesheet" href={url} />)}
  <Fragment set:html={`<style>${themeCss}</style>`} />
  <slot name="head" />
  <ViewTransitions />
</head>
<body data-page={page}>

  <header>
    <div class="header-inner">
      <a href={base || '/'} class="site-title">{settings.title}<b>.</b></a>
      <Nav items={navItems} currentPath={currentPath} />
    </div>
  </header>

  <main>
    <div class={wideLayout ? 'container' : 'narrow'}>
      <slot />
    </div>
  </main>

  <footer>
    <div class="foot-inner">
      <div class="foot-fine">{settings.footer_text} &copy; <span id="year"></span></div>
    </div>
  </footer>

  <!-- _toggleAbstract must be global since it's called via onclick attributes in static HTML -->
  <script is:inline>
    function _toggleAbstract(id, btn) {
      var el = document.getElementById(id);
      var inner = el.firstElementChild;
      var isOpen = el.classList.contains('open');
      if (isOpen) {
        // Pin to current pixel height so the browser has a defined start point
        el.style.gridTemplateRows = inner.scrollHeight + 'px';
        // Double RAF: ensures the browser paints the start state before animating
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            el.style.gridTemplateRows = '0px';
            el.classList.remove('open');
            // After transition, clear inline style so CSS takes back control
            el.addEventListener('transitionend', function cleanup(e) {
              if (e.propertyName === 'grid-template-rows') {
                el.style.gridTemplateRows = '';
                el.removeEventListener('transitionend', cleanup);
              }
            });
          });
        });
      } else {
        el.style.gridTemplateRows = inner.scrollHeight + 'px';
        el.classList.add('open');
      }
      btn.textContent = isOpen ? '≡ Abstract' : '≡ Hide';
    }
  </script>

  <script>
    function setYear() {
      const el = document.getElementById('year');
      if (el) el.textContent = String(new Date().getFullYear());
    }
    setYear();
    document.addEventListener('astro:page-load', setYear);
  </script>

  {settings.analytics_id && (
    <Fragment set:html={`<script defer src="https://cloud.umami.is/script.js" data-website-id="${settings.analytics_id}"></script>`} />
  )}

</body>
</html>
